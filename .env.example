# ===== rl-viewer-queue 設定ファイルのサンプル =====
# このファイルを .env にコピーして値を編集してください。

# OAuth クライアント情報（Google Cloud Console で発行）
# client_secret_xxx.json をダウンロードした場合は CLIENT_SECRET_FILE にそのパスを指定してもOK
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# もしくは JSON ファイルを使う場合（CLIENT_ID/SECRET より優先）
# CLIENT_SECRET_FILE=./client_secret.json

# サーバーのポート
PORT=3000

# 参加希望として検出するキーワード（カンマ区切りで複数可・部分一致）
JOIN_KEYWORDS=参加希望,参加したい,参加します

# チャットのポーリング間隔の下限(ミリ秒)。YouTube推奨値がこれより大きい場合はそちらを優先
MIN_POLL_INTERVAL_MS=4000

# 登録者数・同時視聴者数の取得間隔(ミリ秒)。クォータ節約のため長めを推奨
STATS_INTERVAL_MS=30000

# 試合形式の初期値（1〜4 = 1vs1〜4vs4）。管理画面からいつでも変更可能。
TEAM_SIZE=3
